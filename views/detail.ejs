<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MiniMessageBoard</title>
</head>
<body>
    <div>
        <h2>Author : <%= Author %></h2>
        <h4><%= date %></h4>
        <h3><%= text %></h3>
    </div>
    <button class="BackToMain">Back to main</button>
    <script>
        document.querySelector(".BackToMain").addEventListener("click" , (e) => {
            window.location.href = "/"
        })
    </script>
</body>
</html>